# Copy to .env for local dev (never commit the real .env — it's gitignored).
# In production these are set on the platform (Render/Railway/etc.), not via this file.

# --- Existing CRM config ---
DATABASE_URL=postgresql://mmm:mmm_dev_pw@localhost:5432/mmm_crm
JWT_SECRET=dev-secret-change-in-production
JWT_EXPIRES_IN=7d
PUBLIC_URL=https://crm.mymarketingminder.com
PORT=4000
CORS_ORIGINS=http://localhost:5173
ADMIN_EMAIL=
ADMIN_PASSWORD=

# --- Landing-page auditor (POST /api/audit, POST /api/leads/audit) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

BREVO_API_KEY=
BREVO_SENDER_EMAIL=
BREVO_REPLY_EMAIL=

# Paste the FULL service-account JSON key as ONE minified line (not a file
# path, not a filename) — e.g. `node -e "console.log(JSON.stringify(require('./key.json')))"`
GOOGLE_SERVICE_ACCOUNT_KEY=
GOOGLE_AUDIT_SHEET_ID=
